<Project>
  <!-- Stage Abstractions + Semver/Primitives next to KitLib.dll. Abstractions stays a sibling DLL (no ILRepack). -->
  <PropertyGroup>
    <_KitLibRepoRoot Condition="'$(RepoRoot)' != ''">$(RepoRoot)</_KitLibRepoRoot>
    <_KitLibRepoRoot Condition="'$(_KitLibRepoRoot)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\'))</_KitLibRepoRoot>
    <_SemverDll>$(_KitLibRepoRoot)packages\semver\3.0.0\lib\net5.0\Semver.dll</_SemverDll>
    <_PrimitivesDll>$(_KitLibRepoRoot)packages\microsoft.extensions.primitives\5.0.1\lib\netcoreapp3.0\Microsoft.Extensions.Primitives.dll</_PrimitivesDll>
    <_AbstractionsDll>$(MSBuildProjectDirectory)\..\KitLib.Abstractions\bin\$(Configuration)\net9.0\KitLib.Abstractions.dll</_AbstractionsDll>
    <_KitLibBundleDir>$(_KitLibRepoRoot)build\KitLib\</_KitLibBundleDir>
  </PropertyGroup>
  <Target Name="CopyKitLibAbstractionsRuntimeDeps" AfterTargets="Build">
    <Copy SourceFiles="$(_SemverDll)" DestinationFolder="$(_KitLibBundleDir)" SkipUnchangedFiles="true" Condition="Exists('$(_SemverDll)')" />
    <Copy SourceFiles="$(_PrimitivesDll)" DestinationFolder="$(_KitLibBundleDir)" SkipUnchangedFiles="true" Condition="Exists('$(_PrimitivesDll)')" />
    <Copy SourceFiles="$(_AbstractionsDll)" DestinationFolder="$(_KitLibBundleDir)" SkipUnchangedFiles="true" Condition="Exists('$(_AbstractionsDll)')" />
  </Target>
</Project>
