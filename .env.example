# Copy this file to .env and fill in secrets.
# .env is git-ignored; never commit real keys.
# Shared release IDs (Nexus file groups, STS2_WORKSHOP_ID) live in release.env.

# -------------------------------------------------------------------
# Nexus Mods upload (scripts/publish_nexus.py / make upload-nexus)
# -------------------------------------------------------------------

# Personal API key — https://www.nexusmods.com/settings/api-keys
NEXUS_API_KEY=

# -------------------------------------------------------------------
# NuGet upload (scripts/publish_nuget.py / make upload-nuget)
# -------------------------------------------------------------------

# API key for nuget.org or GitHub Packages
NUGET_API_KEY=

# Feed URL (default: https://api.nuget.org/v3/index.json)
# GitHub Packages example: https://nuget.pkg.github.com/WRXinYue/index.json
NUGET_SOURCE=

# -------------------------------------------------------------------
# Steam Workshop upload (scripts/publish_steam.py / make upload-steam)
# -------------------------------------------------------------------

# Path to ModUploader.exe — https://github.com/megacrit/sts2-mod-uploader/releases
STS2_MOD_UPLOADER=C:\tools\sts2-mod-uploader\ModUploader.exe
