# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real keys.

# -------------------------------------------------------------------
# Nexus Mods upload (scripts/publish_nexus.py / make nexus)
# -------------------------------------------------------------------

# Personal API key — https://www.nexusmods.com/settings/api-keys
NEXUS_API_KEY=

# File group ID for DevMode — mod page → Files tab → any file → API Info
NEXUS_FILE_GROUP_ID=
