<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>ModVariantBundleCompose</AssemblyName>
    <IsPackable>false</IsPackable>
    <RollForward>LatestMajor</RollForward>
    <RepoRoot Condition="'$(RepoRoot)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..\'))</RepoRoot>
    <KitLibAbstractionsProject>$(RepoRoot)src\KitLib.Abstractions\KitLib.Abstractions.csproj</KitLibAbstractionsProject>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(KitLibAbstractionsProject)" />
  </ItemGroup>
</Project>
